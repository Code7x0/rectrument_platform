# =============================================================================
# Production environment — Recruitment Partner Platform
# Copy to .env.local (dev) or set in Vercel Project Settings (production).
# Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# App URL (invite links, emails)
# -----------------------------------------------------------------------------
# Public origin of this deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Optional server-side alias if NEXT_PUBLIC_APP_URL is unset
APP_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Clerk Authentication (Required)
# https://dashboard.clerk.com → API Keys
# -----------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth/callback
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/sign-in

# -----------------------------------------------------------------------------
# Airtable — Partner Relationship Manager (Required)
# https://airtable.com/create/tokens  +  base ID from API docs
# -----------------------------------------------------------------------------
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Schema compatibility (Required for client CRM base)
# client = locked Partner Relationship Manager field map
# app    = normalized app schema (Users / Allocations / Submissions tables)
AIRTABLE_COMPAT_MODE=client

# Allocations strategy (Required for client CRM)
# job_partners = Jobs.Partners multi-link (client base)
# table        = dedicated Allocations table
AIRTABLE_ALLOCATIONS_MODE=job_partners

# Submissions strategy (Required for client CRM)
# candidates = Candidates rows are submission events (client base)
# table      = dedicated Submissions table
AIRTABLE_SUBMISSIONS_MODE=candidates

# Core CRM tables (Required — exact Airtable table names)
AIRTABLE_CLIENTS_TABLE=Clients
AIRTABLE_JOBS_TABLE=Jobs
AIRTABLE_PARTNERS_TABLE=Partners
AIRTABLE_CANDIDATES_TABLE=Candidates

# Staff AM directory (Required in client identity mode — no Users table)
AIRTABLE_ACCOUNT_MANAGERS_TABLE=Account Managers

# Elevated roles when AIRTABLE_USERS_TABLE is blank (Required for Admin / Super Admin login)
# Comma-separated emails, case-insensitive
AIRTABLE_SUPER_ADMIN_EMAILS=superadmin@yourcompany.com
AIRTABLE_ADMIN_EMAILS=admin@yourcompany.com,admin2@yourcompany.com

# Leave blank on locked client base → identity from Account Managers + Partners
AIRTABLE_USERS_TABLE=

# Leave blank when using job_partners / candidates modes
AIRTABLE_ALLOCATIONS_TABLE=
AIRTABLE_SUBMISSIONS_TABLE=

# Optional tables — blank = derived / soft-fail (locked client base)
AIRTABLE_DOCUMENTS_TABLE=
AIRTABLE_PAYOUTS_TABLE=
AIRTABLE_ACTIVITIES_TABLE=
AIRTABLE_NOTIFICATIONS_TABLE=
AIRTABLE_NOTIFICATION_PREFERENCES_TABLE=
AIRTABLE_SETTINGS_TABLE=

# -----------------------------------------------------------------------------
# Providers
# -----------------------------------------------------------------------------
# airtable (only implemented upload provider)
UPLOAD_PROVIDER=airtable
# console | future: resend | sendgrid | ses
EMAIL_PROVIDER=console

# -----------------------------------------------------------------------------
# Diagnostics only (Optional — Settings → System page)
# Vercel sets VERCEL_ENV and VERCEL_GIT_COMMIT_SHA automatically
# -----------------------------------------------------------------------------
# APP_ENV=production
# BUILD_TIMESTAMP=
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=
